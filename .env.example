# Environment configuration
ENVIRONMENT=dev

# API Keys (PLEASE REPLACE WITH YOUR ACTUAL KEYS)
BAILIAN_API_KEY=your_bailian_api_key_here
OPENAI_API_KEY=your_openai_api_key_here
ALIBABA_CLOUD_ACCESS_KEY_ID=your_alibaba_cloud_ak_here
ALIBABA_CLOUD_ACCESS_KEY_SECRET=your_alibaba_cloud_sk_here

# Bailian RAG Configuration
BAILIAN_WORKSPACE_ID=llm-xxx...
BAILIAN_CATEGORY_ID=cate_xxx...
BAILIAN_INDEX_ID=w1f...

# Paths
WORKSPACE_ROOT=/path/to/your/workspace

# LLM Info
DEFAULT_MODEL_NAME=qwen3-coder-plus
MODEL_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# MySQL Configuration
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=your_database_password
MYSQL_DEFAULT_DB=test
MYSQL_CHARSET=utf8mb4

# MongoDB Configuration
MONGODB_URI=mongodb://root:your_database_password@127.0.0.1:27017
MONGODB_DB=chat
